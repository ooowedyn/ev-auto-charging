      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.19 <21",
    "npm": ">=10"
  },
  "devDependencies": {
    "vite": "^7.1.12"
  },
  "dependencies": {
    "three": "^0.180.0"
  }
}
